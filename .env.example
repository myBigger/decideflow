# ═══════════════════════════════════════════════════════
# Dec ideFlow — 环境变量配置
# ═══════════════════════════════════════════════════════
#
# 复制此文件为 .env.local 并填入真实值
#
#   cp .env.example .env.local
#
# ═══════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────
# Supabase（必需）
# 获取地址：https://supabase.com/dashboard → 项目 → Settings → API
# ─────────────────────────────────────────────────────

# 你的 Supabase 项目 URL（不带尾部斜杠）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Supabase 匿名密钥（公开安全，可在前端使用）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase 服务端管理密钥（仅后端使用，不要暴露给前端）
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ─────────────────────────────────────────────────────
# OpenAI（可选 — AI 洞察功能必需）
# 获取地址：https://platform.openai.com/api-keys
# ─────────────────────────────────────────────────────

# 你的 OpenAI API Key
OPENAI_API_KEY=sk-proj-...


# ─────────────────────────────────────────────────────
# Vercel 部署（CI/CD 自动化部署使用）
# 仅在 GitHub Actions / CI 环境中需要
# ─────────────────────────────────────────────────────

# Vercel 个人访问令牌
# https://vercel.com/account/tokens
VERCEL_TOKEN=

# Vercel 组织 ID（从项目 Settings → General 获取）
VERCEL_ORG_ID=team_xxxxxxxx

# Vercel 项目 ID
VERCEL_PROJECT_ID=prj_xxxxxxxx

# Supabase 项目引用 ID（项目 Settings → General）
SUPABASE_PROJECT_REF=xxxxxxxx

# Supabase 个人访问令牌
# https://supabase.com/dashboard → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=

# Supabase 数据库密码（项目 Settings → Database）
SUPABASE_DB_PASSWORD=


# ─────────────────────────────────────────────────────
# 开发环境
# ─────────────────────────────────────────────────────

# Node.js 环境（生产环境由 Vercel 自动配置）
NODE_ENV=development
